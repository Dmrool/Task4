<Window x:Class="ReflectionTaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReflectionTaskManager"
        mc:Ignorable="d"
        Title="Reflection Task Manager" Height="700" Width="800">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- 1. Путь к библиотеке -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
			<TextBlock Text="Путь к DLL:" VerticalAlignment="Center" Width="80"/>
			<TextBox Text="{Binding AssemblyPath, UpdateSourceTrigger=PropertyChanged}"
                     Width="450" Margin="5,0"/>
			<Button Content="Обзор..." Command="{Binding BrowseCommand}"
                    Margin="5,0,0,0" Padding="10,3"/>
			<Button Content="Загрузить" Command="{Binding LoadLibraryCommand}"
                    Margin="5,0,0,0" Padding="15,3" Background="#FF4CAF50" Foreground="White"/>
		</StackPanel>

		<!-- 2. Выбор класса -->
		<StackPanel Grid.Row="1" Margin="0,0,0,10">
			<TextBlock Text="Доступные классы (ILivingBeing):" FontWeight="Bold" Margin="0,0,0,5"/>
			<ComboBox ItemsSource="{Binding ClassNames}"
                      SelectedItem="{Binding SelectedClassName}"
                      Height="25"
                      IsEnabled="{Binding IsLibraryLoaded}"/>
		</StackPanel>

		<!-- 3. Выбор метода -->
		<StackPanel Grid.Row="2" Margin="0,0,0,10">
			<TextBlock Text="Методы класса:" FontWeight="Bold" Margin="0,0,0,5"/>
			<ListBox ItemsSource="{Binding Methods}"
                     SelectedItem="{Binding SelectedMethod}"
                     DisplayMemberPath="DisplayName"
                     Height="100"
                     IsEnabled="{Binding IsLibraryLoaded}"/>
		</StackPanel>

		<!-- 4. Параметры метода -->
		<StackPanel Grid.Row="3" Margin="0,0,0,10">
			<TextBlock Text="Параметры метода (через запятую):" FontWeight="Bold" Margin="0,0,0,5"/>
			<TextBox Text="{Binding ParametersInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="60"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     IsEnabled="{Binding IsLibraryLoaded}">
				<TextBox.ToolTip>
					Введите параметры через запятую в порядке их следования
				</TextBox.ToolTip>
			</TextBox>
			<TextBlock Text="{Binding MethodParameters.Count, StringFormat='Требуется параметров: {0}'}"
                       Margin="0,5,0,0" Foreground="Gray" FontSize="11"/>
		</StackPanel>

		<!-- 5. Кнопка выполнения -->
		<Button Grid.Row="4"
                Content="Выполнить метод"
                Command="{Binding ExecuteMethodCommand}"
                Height="35"
                Margin="0,10"
                FontSize="14"
                Background="#FF2196F3"
                Foreground="White"
                FontWeight="Bold"
                IsEnabled="{Binding IsLibraryLoaded}"/>

		<!-- 6. Результат -->
		<GroupBox Grid.Row="5" Header="Результат выполнения" Margin="0,10,0,0">
			<TextBox Text="{Binding ExecutionResult}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Height="150"
                     Background="#FFF5F5F5"
                     FontFamily="Consolas"
                     Padding="5"/>
		</GroupBox>

		<StatusBar Grid.Row="7">
			<StatusBarItem>
				<TextBlock Text="{Binding ExecutionResult, StringFormat='Статус: {0}'}" />
			</StatusBarItem>
		</StatusBar>
	</Grid>
</Window>